            </Entity>
        </Projection>
        
        <BaseEntities>
            <Entity>Customer</Entity>
            <Entity>PurchaseOrder</Entity>
        </BaseEntities>

        <RelationshipRef>CustomerPurchaseJoin</RelationshipRef>

        <!-- Both SQL filter on Customer AND XML filter on PurchaseOrder -->
        <Filters>
            <Filter>
                <Entity>Customer</Entity>
                <Attribute>city</Attribute>
                <Operator>=</Operator>
                <Value>New York</Value>
            </Filter>
            <Filter>
                <Entity>PurchaseOrder</Entity>
                <Query>/PurchaseOrders/PurchaseOrder [amount > 5000]</Query>
            </Filter>
        </Filters>

        
    </View>

